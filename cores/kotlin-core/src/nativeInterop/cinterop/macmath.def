headers = math.h
linkerOpts.osx = -lm
---
// _DARWIN_C_SOURCE must be defined before <math.h> is included to expose sinpi/cospi/etc.
// as the static-inline SDK definitions they are in macOS 15+. The cinterop tool compiles
// the C section without automatically including the 'headers' directive entries, so the
// define and include must appear here explicitly.
#define _DARWIN_C_SOURCE
#include <math.h>

static inline double kotlin_sinpi(double x)  { return sinpi(x);  }
static inline float  kotlin_sinpif(float x)  { return sinpif(x); }
static inline double kotlin_cospi(double x)  { return cospi(x);  }
static inline float  kotlin_cospif(float x)  { return cospif(x); }
static inline double kotlin_tanpi(double x)  { return tanpi(x);  }
static inline float  kotlin_tanpif(float x)  { return tanpif(x); }
static inline double kotlin_asinpi(double x) { return asinpi(x); }
static inline float  kotlin_asinpif(float x) { return asinpif(x); }
static inline double kotlin_acospi(double x) { return acospi(x); }
static inline float  kotlin_acospif(float x) { return acospif(x); }
static inline double kotlin_atanpi(double x) { return atanpi(x); }
static inline float  kotlin_atanpif(float x) { return atanpif(x); }
static inline double kotlin_atan2pi(double y, double x)  { return atan2pi(y, x);  }
static inline float  kotlin_atan2pif(float y, float x)   { return atan2pif(y, x); }
